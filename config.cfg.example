Exemple de configuration nécessaire pour utiliser le programme.
Copiez ce fichier vers config/app.cfg et renseignez les valeurs.

[smtp]
host = smtp.example.com
port = 587
from = votre_adresse@example.com
; Le mot de passe est lu depuis la variable d'environnement SMTP_PASSWORD

[agent]
; Adresse email destinataire du briefing hebdomadaire (optionnel)
email_to =
; Chemin de sortie des briefings (défaut : data/briefings/)
output_dir =
