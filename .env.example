# Variables d'environnement — Agent de veille technologique
# Copiez ce fichier en .env et renseignez les valeurs.
# Le fichier .env est gitignore et ne doit JAMAIS être commité.

# ---------------------------------------------------------------------------
# API Claude (obligatoire)
# Générez une clé sur https://console.anthropic.com/settings/keys
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Gmail — envoi du briefing hebdomadaire (optionnel)
# 1. Activez la validation en 2 étapes sur votre compte Google
# 2. Générez un mot de passe d'application sur :
#    https://myaccount.google.com/apppasswords
#    (choisir "Autre" et nommer-le "veille_agent")
# 3. Copiez les 16 caractères (sans espaces) dans GMAIL_APP_PASSWORD
# ---------------------------------------------------------------------------
GMAIL_FROM=votre.adresse@gmail.com
GMAIL_APP_PASSWORD=abcdabcdabcdabcd

# ---------------------------------------------------------------------------
# GitHub (optionnel — augmente la limite de 60 à 5000 req/h)
# Utile uniquement si vous surveillez plus de 10 topics GitHub
# Générez un token sur https://github.com/settings/tokens (scope: public_repo)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=
