# Variables d'environnement — Agent de veille technologique
# Copiez ce fichier en .env et renseignez les valeurs.
# Le fichier .env est gitignore et ne doit JAMAIS être commité.

# ---------------------------------------------------------------------------
# API Claude (obligatoire)
# Générez une clé sur https://console.anthropic.com/settings/keys
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Modèle utilisé pour le scoring/tagging en masse (analyze_batch).
# Tâche de classification structurée — Haiku est recommandé par
# Anthropic pour ce type d'usage (voir "Choosing a model" dans la doc).
CLAUDE_MODEL_BATCH=claude-haiku-4-5

# Modèle utilisé pour les deepdives (articles score >= 9, recherche web
# + synthèse) et le recap mensuel. Volume faible, tâche plus agentique
# → modèle plus capable justifié.
# Vérifier https://platform.claude.com/docs/en/about-claude/model-deprecations
# avant toute mise à jour.
CLAUDE_MODEL_DEEPDIVE=claude-sonnet-5

# ---------------------------------------------------------------------------
# Gmail — envoi du briefing hebdomadaire (optionnel)
# 1. Activez la validation en 2 étapes sur votre compte Google
# 2. Générez un mot de passe d'application sur :
#    https://myaccount.google.com/apppasswords
#    (choisir "Autre" et nommer-le "veille_agent")
# 3. Copiez les 16 caractères (sans espaces) dans GMAIL_APP_PASSWORD
# ---------------------------------------------------------------------------
GMAIL_FROM=votre.adresse@gmail.com
GMAIL_APP_PASSWORD=abcdabcdabcdabcd

# Adresse destinataire du briefing hebdomadaire
# Peut être la même que GMAIL_FROM, ou une adresse différente
# Peut aussi être passée en CLI : python -m veille_agent --email adresse@example.com
GMAIL_TO=destinataire@example.com

# Répertoire optionnel où copier le briefing markdown en plus de
# data/briefings/ (ex : point de montage vers un vault Obsidian).
# Alternative à --publish-path en CLI.
# PUBLISH_PATH=/publish

# ---------------------------------------------------------------------------
# YouTube Data API v3 (optionnel — requis pour collect_youtube)
# Générez une clé sur https://console.cloud.google.com/apis/credentials
# Activez l'API "YouTube Data API v3" dans votre projet Google Cloud
# Quota gratuit : 10 000 unités/jour (largement suffisant)
# ---------------------------------------------------------------------------
YOUTUBE_API_KEY=AIza...

# ---------------------------------------------------------------------------
# GitHub (optionnel — augmente la limite de 60 à 5000 req/h)
# Utile uniquement si vous surveillez plus de 10 topics GitHub
# Générez un token sur https://github.com/settings/tokens (scope: public_repo)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=
